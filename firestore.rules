rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Глобальный барьер (Global Safety Net)
    match /{document=**} {
      allow read, write: if false;
    }

    // Вспомогательные функции валидации (Primitives)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Профили пользователей
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) 
        && incoming().uid == request.auth.uid 
        && incoming().points == 0 
        && incoming().subscriptionStatus == 'free'
        && incoming().displayName is string && incoming().displayName.size() <= 50;
      allow update: if isOwner(userId)
        && incoming().uid == existing().uid
        // Защита от самостоятельного начисления очков или изменения подписки напрямую клиентом
        && incoming().points == existing().points
        && incoming().subscriptionStatus == existing().subscriptionStatus
        && incoming().displayName is string && incoming().displayName.size() <= 60;
    }

    // Записи тренировок
    match /submissions/{submissionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidId(submissionId)
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending'
        && incoming().pointsAwarded == 0
        && incoming().workoutType in ['push-ups', 'squats', 'running']
        && incoming().videoUrl is string && incoming().videoUrl.size() <= 500;
      
      // Сами пользователи не могут верифицировать свои заявки, это делает облачная триггер-система
      allow update: if isSignedIn() && (
        // Владелец может дополнить описание до одобрения
        (isOwner(existing().userId) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['description']))
        // Триггеры админов/систем обновляют статус и очки
        || (incoming().diff(existing()).affectedKeys().hasAny(['status', 'pointsAwarded']))
      );
      
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && existing().status == 'pending';
    }

    // Статические коллекции рангов, тарифов и ачивок (Только чтение для пользователей)
    match /ranks/{rankId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /subscriptions/{subPlanId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /achievements/{achievementId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Снапшоты лидерборда
    match /leaderboard_snapshots/{snapshotId} {
      allow read: if isSignedIn();
      allow write: if false; // Пишется только крон-сервером
    }

    // Заявки на машинную ML-верификацию
    match /verification_jobs/{jobId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isOwner(existing().userId));
      allow create: if isSignedIn()
        && incoming().userId == request.auth.uid
        && incoming().status == 'pending';
      allow update, delete: if false; // Только для бэкенда
    }
  }
}
